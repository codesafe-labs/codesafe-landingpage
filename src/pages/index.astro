---
export const prerender = true;

import MarketingLayout from '../layouts/MarketingLayout.astro';
import Nav from '../components/marketing/Nav.astro';
import Footer from '../components/marketing/Footer.astro';
import Hero from '../components/marketing/sections/Hero.astro';
import HowItWorks from '../components/marketing/sections/HowItWorks.astro';
import FixPrShowcase from '../components/marketing/sections/FixPrShowcase.astro';
import WhatItChecks from '../components/marketing/sections/WhatItChecks.astro';
import FreeScan from '../components/marketing/sections/FreeScan.astro';
import OpenSource from '../components/marketing/sections/OpenSource.astro';
import Pricing from '../components/marketing/sections/Pricing.astro';
import Faq from '../components/marketing/sections/Faq.astro';
import Waitlist from '../components/marketing/sections/Waitlist.astro';
---

<MarketingLayout scanlines>
	<Nav slot="nav" variant="landing" />
	<Hero />
	<HowItWorks />
	<FixPrShowcase />
	<WhatItChecks />
	<FreeScan />
	<OpenSource />
	<Pricing />
	<Faq />
	<Waitlist />
	<Footer slot="footer" variant="landing" />
</MarketingLayout>
