---
export const prerender = true;

import { getCollection } from 'astro:content';
import MarketingLayout from '../../layouts/MarketingLayout.astro';
import Nav from '../../components/marketing/Nav.astro';
import Footer from '../../components/marketing/Footer.astro';
import ChangelogEntry from '../../components/marketing/changelog/ChangelogEntry.astro';
import SubscribeCTA from '../../components/marketing/changelog/SubscribeCTA.astro';

const entries = await getCollection('changelog');
const sorted = entries.sort(
	(a, b) => b.data.date.getTime() - a.data.date.getTime(),
);
---

<MarketingLayout
	title="Changelog · codesafe.sh"
	description="Every release, new rule, and fix. Building in the open, shipped from Austria."
>
	<Nav slot="nav" variant="subpage" subpageLabel="═══ CHANGELOG ═══" />

	<div class="mx-auto max-w-changelog px-8 pb-24 pt-12">
		<div class="flex max-w-[560px] flex-col gap-3.5">
			<span class="crt-section-label">═══ CHANGELOG ═══</span>
			<h1
				class="m-0 text-[46px] font-bold leading-[1.05] text-crt-cream text-balance"
			>
				What's new in codesafe
			</h1>
			<p class="m-0 text-[16.5px] leading-relaxed text-crt-body text-pretty">
				Every release, new rule, and fix. Building in the open, shipped from
				Austria.
			</p>
		</div>

		<div class="mt-14 flex flex-col">
			{
				sorted.map((entry) => (
					<ChangelogEntry
						date={entry.data.date}
						tag={entry.data.tag}
						version={entry.data.version}
						title={entry.data.title}
						description={entry.data.description}
						items={entry.data.items}
					/>
				))
			}
		</div>

		<SubscribeCTA />
	</div>

	<Footer slot="footer" variant="subpage" />
</MarketingLayout>
