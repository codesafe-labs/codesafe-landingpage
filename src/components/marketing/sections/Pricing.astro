---
import { plansData, compareRows } from '../../../data/landing';
---

<section id="pricing" class="crt-divider">
	<div class="mx-auto max-w-landing px-8 py-[72px]">
		<div class="flex flex-col items-center gap-3.5 text-center">
			<span class="crt-section-label">═══ PRICING ═══</span>
			<h2
				class="m-0 text-[34px] font-bold leading-[1.15] text-crt-cream text-balance"
			>
				FREE FOREVER. PAY ONLY FOR HOSTING.
			</h2>
		</div>
		<div class="mt-11 grid items-stretch gap-4 sm:grid-cols-2 lg:grid-cols-4">
			{
				plansData.map((plan) => (
					<div
						class:list={[
							'relative flex flex-col gap-4 px-[22px] py-[26px]',
							plan.featured
								? 'border border-crt-amber bg-crt-surface-accent'
								: 'border border-crt-border bg-crt-surface',
						]}
					>
						{plan.featured && (
							<span class="absolute -top-2.5 left-[22px] bg-crt-amber px-2.5 py-[3px] text-[10.5px] font-bold tracking-[0.08em] text-crt-bg">
								MOST POPULAR
							</span>
						)}
						<div class="flex flex-col gap-1.5">
							<h3 class="m-0 text-[12.5px] font-bold tracking-[0.06em] text-crt-amber">
								{plan.name}
							</h3>
							<div class="flex items-baseline gap-1">
								<span class="text-[32px] font-bold text-crt-cream tabular-nums">
									{plan.price}
								</span>
								<span class="text-xs text-crt-muted">{plan.per}</span>
							</div>
							<p class="m-0 text-xs leading-[1.6] text-crt-muted">
								{plan.tagline}
							</p>
						</div>
						<ul class="m-0 flex flex-1 list-none flex-col gap-2 p-0 text-xs text-crt-body">
							{plan.features.map((feat) => (
								<li class="flex gap-2">
									<span class="text-crt-green">✓</span>
									<span>{feat}</span>
								</li>
							))}
						</ul>
						<a
							href="#waitlist"
							class:list={[
								'border px-3.5 py-[11px] text-center text-xs font-bold tracking-[0.04em] no-underline transition-colors focus-visible:outline-2 focus-visible:outline-crt-amber focus-visible:outline-offset-2',
								plan.featured
									? 'border-crt-amber bg-crt-amber text-crt-bg hover:bg-crt-amber-hover'
									: 'border-crt-amber bg-transparent text-crt-amber hover:bg-crt-amber hover:text-crt-bg',
							]}
						>
							{plan.cta}
						</a>
					</div>
				))
			}
		</div>

		<div
			class="crt-card mt-12 flex flex-col gap-[26px] p-9"
		>
			<div class="flex flex-col items-center gap-2.5 text-center">
				<h3
					class="m-0 text-[22px] font-bold tracking-[0.02em] text-crt-cream"
				>
					NO ARTIFICIAL LIMITATIONS.
				</h3>
				<p
					class="m-0 max-w-[480px] text-[13px] leading-[1.7] text-crt-body text-pretty"
				>
					The self-hosted version has every feature. You only pay if you want us
					to host it.
				</p>
			</div>
			<div
				class="mx-auto w-full max-w-[720px] border border-dashed border-crt-border"
			>
				<div
					class="grid grid-cols-[1.3fr_1fr_1fr] gap-4 border-b border-dashed border-crt-border px-[22px] py-[11px] text-[11px] font-bold tracking-[0.08em] text-crt-amber tabular-nums"
				>
					<span></span>
					<span>SELF-HOSTED</span>
					<span>CLOUD</span>
				</div>
				{
					compareRows.map((row) => (
						<div class="grid grid-cols-[1.3fr_1fr_1fr] items-baseline gap-4 border-b border-[#1E1810] px-[22px] py-2.5 text-xs last:border-b-0 tabular-nums">
							<span class="text-crt-cream">{row.label}</span>
							<span class="text-crt-body">{row.self}</span>
							<span class="text-crt-body">{row.cloud}</span>
						</div>
					))
				}
			</div>
		</div>
	</div>
</section>
