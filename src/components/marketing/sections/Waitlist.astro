---
import WaitlistForm from '../../islands/WaitlistForm.tsx';
---

<section id="waitlist" class="crt-divider">
	<div
		class="mx-auto flex max-w-[680px] flex-col items-center gap-5 px-8 py-[88px] text-center"
	>
		<h2
			class="m-0 text-[40px] font-bold leading-[1.1] text-crt-cream text-balance"
		>
			YOUR APP IS LIVE.<br /><span class="text-crt-amber">IS IT SAFE?</span>
		</h2>
		<p
			class="m-0 max-w-[460px] text-[13.5px] leading-[1.8] text-crt-body text-pretty"
		>
			Cloud scans and auto-PRs are rolling out to the waitlist first. The CLI is
			free today.
		</p>
		<WaitlistForm client:load />
		<span class="text-[11px] tracking-[0.08em] text-crt-faint"
			>NO SPAM. ONE EMAIL WHEN YOUR INVITE IS READY.</span
		>
	</div>
</section>
