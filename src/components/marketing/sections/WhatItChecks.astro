---
import { checksData } from '../../../data/landing';
---

<section id="checks" class="crt-divider">
	<div class="mx-auto max-w-landing px-8 py-[72px]">
		<div class="flex flex-wrap items-end justify-between gap-8">
			<div class="flex max-w-[620px] flex-col gap-3.5">
				<span class="crt-section-label">═══ WHAT IT CHECKS ═══</span>
				<h2
					class="m-0 text-[34px] font-bold leading-[1.15] text-crt-cream text-balance"
				>
					BUILT ON OWASP, TUNED FOR AI-GENERATED CODE
				</h2>
			</div>
			<p class="m-0 max-w-xs text-[12.5px] leading-[1.7] text-crt-muted text-pretty">
				Not a generic linter: rules target the specific patterns Claude, Cursor,
				and Lovable produce.
			</p>
		</div>
		<div class="mt-10 grid gap-4 sm:grid-cols-2 lg:grid-cols-3">
			{
				checksData.map((check) => (
					<div class="flex flex-col gap-2.5 border border-crt-border bg-crt-surface p-[22px]">
						<span class="text-[11px] tracking-[0.08em] text-crt-muted">
							{check.owasp}
						</span>
						<h3 class="m-0 text-[14.5px] font-bold tracking-[0.02em] text-crt-cream">
							{check.title}
						</h3>
						<p class="m-0 text-[12.5px] leading-[1.7] text-crt-body text-pretty">
							{check.desc}
						</p>
					</div>
				))
			}
		</div>
	</div>
</section>
