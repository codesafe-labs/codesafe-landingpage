---
import { checksData } from '../../../data/landing';
---

<section id="checks" class="border-t border-border bg-cream">
	<div class="mx-auto max-w-landing px-8 py-[88px]">
		<div
			class="flex flex-wrap items-end justify-between gap-8"
		>
			<div class="flex max-w-[560px] flex-col gap-3">
				<span
					class="font-mono text-[13px] font-semibold tracking-[0.06em] text-green"
					>WHAT IT CHECKS</span
				>
				<h2
					class="m-0 font-display text-[38px] font-bold leading-[1.1] tracking-tight"
				>
					Built on OWASP, tuned for AI-generated code
				</h2>
			</div>
			<p class="m-0 max-w-xs text-[15px] text-subtle text-pretty">
				Not a generic linter: rules target the specific patterns Claude, Cursor,
				and Lovable produce.
			</p>
		</div>
		<div
			class="mt-11 grid gap-5 sm:grid-cols-2 lg:grid-cols-3"
		>
			{
				checksData.map((check) => (
					<div class="flex flex-col gap-2.5 rounded-[14px] border border-border bg-white p-6">
						<span class="font-mono text-xs font-semibold text-faint">
							{check.owasp}
						</span>
						<h3 class="m-0 text-[17px] font-semibold">{check.title}</h3>
						<p class="m-0 text-sm leading-relaxed text-muted text-pretty">
							{check.desc}
						</p>
					</div>
				))
			}
		</div>
	</div>
</section>
