---
import FaqAccordion from '../../islands/FaqAccordion.tsx';
import { faqData } from '../../../data/landing';
---

<section id="faq" class="crt-divider">
	<div class="mx-auto max-w-faq px-8 py-[72px]">
		<div class="flex flex-col items-center gap-3.5 text-center">
			<span class="crt-section-label">═══ FAQ ═══</span>
			<h2
				class="m-0 text-[34px] font-bold leading-[1.15] text-crt-cream text-balance"
			>
				QUESTIONS, ANSWERED HONESTLY
			</h2>
		</div>
		<FaqAccordion client:visible items={faqData} />
	</div>
</section>
