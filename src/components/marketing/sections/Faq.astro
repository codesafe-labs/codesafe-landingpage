---
import FaqAccordion from '../../islands/FaqAccordion.tsx';
import { faqData } from '../../../data/landing';
---

<section id="faq" class="border-t border-border bg-white">
	<div class="mx-auto max-w-faq px-8 py-[88px]">
		<div class="flex flex-col items-center gap-3 text-center">
			<span
				class="font-mono text-[13px] font-semibold tracking-[0.06em] text-green"
				>FAQ</span
			>
			<h2
				class="m-0 font-display text-[38px] font-bold leading-[1.1] tracking-tight"
			>
				Questions, answered honestly
			</h2>
		</div>
		<FaqAccordion client:visible items={faqData} />
	</div>
</section>
