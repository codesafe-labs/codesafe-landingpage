---
import TerminalAnimation from '../../islands/TerminalAnimation.tsx';
import { terminalLines } from '../../../data/landing';
---

<header
	id="scan"
	class="mx-auto grid max-w-landing items-center gap-14 px-8 pb-[72px] pt-[76px] lg:grid-cols-[1.05fr_0.95fr]"
>
	<div class="flex animate-cs-rise flex-col gap-6">
		<div class="crt-section-label text-crt-muted">
			═══ OPEN SOURCE · APACHE 2.0 · MADE IN THE EU ═══
		</div>
		<h1
			class="m-0 text-[60px] font-bold leading-[1.05] tracking-[-0.01em] text-crt-cream text-balance"
		>
			SHIP<br />WITHOUT<br /><span class="text-crt-amber">FEAR_</span>
		</h1>
		<p class="m-0 max-w-[440px] text-sm leading-[1.8] text-crt-body text-pretty">
			Your AI wrote the app. <span translate="no">codesafe</span> finds the security
			holes it left behind and opens a <strong class="font-semibold text-crt-cream"
				>pull request that fixes them</strong
			>. NOT A REPORT. A FIX.
		</p>
		<div class="flex flex-wrap items-center gap-3.5">
			<a href="#waitlist" class="crt-btn-primary text-sm">
				JOIN WAITLIST ▸
			</a>
			<a href="#pr" class="crt-btn-ghost text-[13px]">
				SEE A FIX PR ▸
			</a>
		</div>
		<div class="text-[11.5px] tracking-[0.06em] text-crt-faint">
			FREE SCAN & SCORE ── ZERO RUNTIME DEPENDENCIES ── BUILT IN AUSTRIA
		</div>
	</div>

	<TerminalAnimation client:visible lines={terminalLines} />
</header>
