---
import SubscribeForm from '../../islands/SubscribeForm.tsx';
---

<div
	class="crt-card mt-6 flex flex-wrap items-center justify-between gap-6 border-crt-amber p-8"
>
	<div class="flex flex-col gap-1.5">
		<h3 class="m-0 text-[21px] font-bold text-crt-cream">
			Get release notes by email
		</h3>
		<p class="m-0 text-[14.5px] text-crt-body">
			One short email per release. No marketing.
		</p>
	</div>
	<SubscribeForm client:load />
</div>
