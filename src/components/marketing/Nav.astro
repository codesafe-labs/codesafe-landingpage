---
import { site } from '../../config/site';

interface Props {
	variant?: 'landing' | 'subpage';
	subpageLabel?: string;
	width?: 'changelog' | 'imprint';
}

const { variant = 'landing', subpageLabel, width = 'changelog' } = Astro.props;

const widthClass = width === 'imprint' ? 'max-w-imprint' : 'max-w-changelog';
---

<nav
	class:list={[
		'mx-auto flex items-center justify-between gap-6 border-b border-dashed border-crt-border px-8 py-5',
		variant === 'landing' ? 'max-w-landing' : widthClass,
	]}
>
	<a href="/" class="flex items-center no-underline">
		<span class="text-[15px] font-semibold text-crt-cream">
			<span class="text-crt-amber" aria-hidden="true">▮</span> CODESAFE.SH
		</span>
	</a>

	{
		variant === 'landing' ? (
			<>
				<div class="hidden items-center gap-6 text-[12.5px] text-crt-muted md:flex">
					<a
						href="#how"
						class="text-inherit no-underline transition-colors hover:text-crt-cream focus-visible:outline-2 focus-visible:outline-crt-amber focus-visible:outline-offset-2"
					>
						[F1] HOW
					</a>
					<a
						href="#checks"
						class="text-inherit no-underline transition-colors hover:text-crt-cream focus-visible:outline-2 focus-visible:outline-crt-amber focus-visible:outline-offset-2"
					>
						[F2] CHECKS
					</a>
					<a
						href="#pricing"
						class="text-inherit no-underline transition-colors hover:text-crt-cream focus-visible:outline-2 focus-visible:outline-crt-amber focus-visible:outline-offset-2"
					>
						[F3] PRICING
					</a>
					<a
						href="#faq"
						class="text-inherit no-underline transition-colors hover:text-crt-cream focus-visible:outline-2 focus-visible:outline-crt-amber focus-visible:outline-offset-2"
					>
						[F4] FAQ
					</a>
					<a
						href="/blog"
						class="text-inherit no-underline transition-colors hover:text-crt-cream focus-visible:outline-2 focus-visible:outline-crt-amber focus-visible:outline-offset-2"
					>
						[F5] CHANGELOG
					</a>
				</div>
				<div class="flex items-center gap-3 text-[12.5px]">
					<a
						href={site.github}
						class="hidden border border-crt-border-strong px-3 py-[7px] text-crt-muted no-underline transition-colors hover:border-crt-amber hover:text-crt-cream focus-visible:outline-2 focus-visible:outline-crt-amber focus-visible:outline-offset-2 sm:inline-flex"
					>
						★ STAR ON GITHUB
					</a>
					<a href="#waitlist" class="crt-btn-outline">
						JOIN WAITLIST ▸
					</a>
				</div>
			</>
		) : (
			<div class="flex items-center gap-6 text-[12.5px] font-semibold">
				{subpageLabel && (
					<span class="crt-section-label">{subpageLabel}</span>
				)}
				<a
					href="/"
					class="text-crt-muted no-underline transition-colors hover:text-crt-cream focus-visible:outline-2 focus-visible:outline-crt-amber focus-visible:outline-offset-2"
				>
					← BACK TO HOME
				</a>
			</div>
		)
	}
</nav>
