---
import { site } from '../../config/site';

interface Props {
	variant?: 'landing' | 'subpage';
	width?: 'changelog' | 'imprint';
}

const { variant = 'landing', width = 'changelog' } = Astro.props;

const widthClass = width === 'imprint' ? 'max-w-imprint' : 'max-w-changelog';
---

<footer class="crt-divider">
	<div
		class:list={[
			'mx-auto flex flex-wrap items-center justify-between gap-6 px-8 py-[26px] text-[11.5px] text-crt-muted',
			variant === 'landing' ? 'max-w-landing' : widthClass,
		]}
	>
		{
			variant === 'landing' ? (
				<span class="font-semibold text-crt-cream">
					<span class="text-crt-amber" aria-hidden="true">
						▮
					</span>{' '}
					CODESAFE.SH{' '}
					<span class="ml-2 font-normal text-crt-faint">
						MADE IN AUSTRIA · HOSTED IN THE EU
					</span>
				</span>
			) : (
				<span class="font-semibold text-crt-cream">
					<span class="text-crt-amber" aria-hidden="true">
						▮
					</span>{' '}
					CODESAFE.SH
				</span>
			)
		}
		<div class="flex flex-wrap gap-[22px]">
			{
				variant === 'landing' && (
					<>
						<a
							href={site.github}
							class="text-inherit uppercase no-underline transition-colors hover:text-crt-cream focus-visible:outline-2 focus-visible:outline-crt-amber focus-visible:outline-offset-2"
						>
							GITHUB
						</a>
						<a
							href={site.docs}
							class="text-inherit uppercase no-underline transition-colors hover:text-crt-cream focus-visible:outline-2 focus-visible:outline-crt-amber focus-visible:outline-offset-2"
						>
							DOCS
						</a>
						<a
							href="/blog"
							class="text-inherit uppercase no-underline transition-colors hover:text-crt-cream focus-visible:outline-2 focus-visible:outline-crt-amber focus-visible:outline-offset-2"
						>
							CHANGELOG
						</a>
					</>
				)
			}
			<a
				href="/imprint"
				class="text-inherit uppercase no-underline transition-colors hover:text-crt-cream focus-visible:outline-2 focus-visible:outline-crt-amber focus-visible:outline-offset-2"
			>
				IMPRINT
			</a>
			<a
				href="/privacy"
				class="text-inherit uppercase no-underline transition-colors hover:text-crt-cream focus-visible:outline-2 focus-visible:outline-crt-amber focus-visible:outline-offset-2"
			>
				PRIVACY
			</a>
			<span>© 2026 CODESAFE</span>
		</div>
	</div>
</footer>
